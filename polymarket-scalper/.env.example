# Polymarket credentials
# Get your private key from Polymarket settings → Export Private Key
POLYMARKET_PRIVATE_KEY=your_private_key_here

# Your proxy/funder wallet address (the address that holds USDC on Polymarket)
# Find it at polymarket.com → Profile → Wallet address
POLYMARKET_FUNDER=your_funder_address_here

# Signature type: 0=EOA, 1=Magic/Email wallet, 2=Browser wallet proxy
POLYMARKET_SIGNATURE_TYPE=2

# Trading config
CAPITAL=100
MAX_EXPOSURE_PCT=50
PER_ORDER=10
MAX_CONCURRENT=5
CIRCUIT_BREAKER_PCT=10
MAX_HOLD_SECONDS=300
SPREAD_CAPTURE_TARGET=0.02
REPRICE_INTERVAL=15

# Strategy: one_side or both_sides (market making)
STRATEGY=one_side

# Quiet hours REMOVED — bot runs 24/7
# QUIET_HOURS_START and QUIET_HOURS_END no longer used

# Post-only orders: guarantee maker status (default: true)
POST_ONLY=true

# AI Supervisor mode: all orders checked against rules.jsonl (default: false)
SUPERVISED=false
